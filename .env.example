# =====================================================
# Environment variables for the storefront
# -----------------------------------------------------
# On Render: set these under  Service -> Settings -> Environment.
# Locally with Docker Compose: these are already wired up in
# docker-compose.yml (Postgres), so you don't need this file there.
# =====================================================

# ---- Database (PostgreSQL / Neon) ----
# Easiest: paste the full connection string Neon gives you.
# (Use the POOLED connection string for a web app.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ...or set the discrete parts instead of DATABASE_URL:
# DB_HOST=ep-xxxx.region.aws.neon.tech
# DB_PORT=5432
# DB_USER=neondb_owner
# DB_PASS=your_password
# DB_NAME=neondb
# DB_SSLMODE=require

# ---- Cloudinary (product image uploads) ----
# Create an UNSIGNED upload preset in Cloudinary and put its name here.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# ---- Google OAuth (optional: "Sign up with Google") ----
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
